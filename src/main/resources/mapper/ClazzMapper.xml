<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ClazzMapper">
    <insert id="addClazz">
        INSERT INTO clazz
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="room != null and room != ''">room,</if>
            <if test="beginDate != null">begin_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="masterId != null">master_id,</if>
            <if test="subject != null">subject,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="room != null and room != ''">#{room},</if>
            <if test="beginDate != null">#{beginDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="masterId != null">#{masterId},</if>
            <if test="subject != null">#{subject},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime}</if>
        </trim>
    </insert>
    <update id="updateById">
        UPDATE clazz
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="room != null and room != ''">room = #{room},</if>
            <if test="beginDate != null">begin_date = #{beginDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="masterId != null">master_id = #{masterId},</if>
            <if test="subject != null">subject = #{subject},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime}</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="getClazzs" resultType="com.example.pojo.dto.ClazzVO">
        SELECT
        c.id,
        c.name,
        c.room,
        c.begin_date AS beginDate,
        c.end_date AS endDate,
        c.master_id AS masterId,
        c.create_time AS createTime,
        c.update_time AS updateTime,
        e.name AS masterName  <!-- 关键：从 emp 表获取 -->
        FROM clazz c
        LEFT JOIN emp e ON c.master_id = e.id  <!-- 左连接，允许班主任为空 -->
        <where>
            <!-- 班级名称模糊查询 -->
            <if test="dto.name != null and dto.name != ''">
                AND c.name LIKE CONCAT('%', #{dto.name}, '%')
            </if>

            <!-- 结课时间范围：注意字段是 c.end_date -->
            <if test="dto.begin != null">
                AND c.end_date >= #{dto.begin}
            </if>
            <if test="dto.end != null">
                AND c.end_date &lt;= #{dto.end}
            </if>
        </where>
        ORDER BY c.create_time DESC
        LIMIT #{dto.start}, #{dto.pageSize}
    </select>
    <select id="countByCondition" resultType="int">
        SELECT COUNT(*)
        FROM clazz c
        <where>
            <if test="dto.name != null and dto.name != ''">
                AND c.name LIKE CONCAT('%', #{dto.name}, '%')
            </if>
            <if test="dto.begin != null">
                AND c.end_date >= #{dto.begin}
            </if>
            <if test="dto.end != null">
                AND c.end_date &lt;= #{dto.end}
            </if>
        </where>
    </select>
</mapper>